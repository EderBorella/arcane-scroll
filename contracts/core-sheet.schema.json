{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:arcane:contract:core-sheet:1",
  "title": "CoreSheet",
  "description": "Permanent always-active character facts. No live-play counters, no spellcasting, no items, no derived values. Content-neutral: catalog-driven, never enumerates game vocabulary.",
  "type": "object",
  "required": [
    "schema_version",
    "character_id",
    "character_name",
    "identity",
    "abilities",
    "proficiency_bonus",
    "saving_throws",
    "skills",
    "proficiencies",
    "languages",
    "features",
    "feats"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "character_id": {
      "type": "string",
      "description": "Global unique identifier for this character, shared across all 5 schemas."
    },
    "character_name": {
      "type": "string",
      "description": "Character name, shared across all 5 schemas."
    },
    "meta": {
      "description": "Non-sheet provenance. Optional; ignored by the validator.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "seed": {
          "type": ["integer", "string", "null"]
        },
        "request": {
          "type": ["object", "null"]
        }
      }
    },
    "identity": {
      "type": "object",
      "required": ["name", "species", "size", "creature_type", "classes", "total_level", "background"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "species": {
          "type": "string"
        },
        "lineage": {
          "type": ["string", "null"]
        },
        "species_variant": {
          "description": "Single-axis species variant pick (the chosen option name). For a species offering more than one independent variant axis, use species_variants.",
          "type": ["string", "null"]
        },
        "species_variants": {
          "description": "Per-axis species variant picks for a species with more than one independent variant axis: a map of axis name to the chosen option name.",
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" }
        },
        "size": {
          "type": "string"
        },
        "creature_type": {
          "type": "string"
        },
        "classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/classEntry" }
        },
        "total_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "background": {
          "type": "string"
        },
        "alignment": {
          "type": ["string", "null"]
        },
        "player": {
          "type": ["string", "null"]
        }
      }
    },
    "abilities": {
      "description": "One entry per ability. Keys are ability identifiers from the catalog. Permanent scores only — no modifier or reduction.",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/abilityEntry"
      }
    },
    "proficiency_bonus": {
      "type": "integer",
      "minimum": 2,
      "maximum": 6
    },
    "saving_throws": {
      "description": "One entry per ability, keyed by ability identifier. Proficient only — no derived modifier.",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["proficient"],
        "additionalProperties": false,
        "properties": {
          "proficient": {
            "type": "boolean"
          }
        }
      }
    },
    "skills": {
      "description": "One entry per skill, keyed by skill identifier. Static definitions only — no derived modifier.",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["ability", "proficient", "expertise"],
        "additionalProperties": false,
        "properties": {
          "ability": {
            "type": "string"
          },
          "proficient": {
            "type": "boolean"
          },
          "expertise": {
            "type": "boolean"
          },
          "source": {
            "enum": ["class", "background", "species", "feat", "feature", "item", null]
          }
        }
      }
    },
    "permanent_senses": {
      "description": "Always-on special senses from species, feats, features. Key = sense catalog ID -> range in feet. Does NOT include temporary senses from spells/effects.",
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "permanent_speed": {
      "description": "Always-on movement speeds from species, feats, features. Key = mode catalog ID -> feet. Does NOT include conditional bonuses (spell-granted speed modifiers, class-feature speed bonuses).",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "permanent_defenses": {
      "description": "Always-on damage/condition defences from species, feats, features, attuned items. Does NOT include temporary defences from spells/effects.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resistances": {
          "type": "array",
          "items": { "type": "string" }
        },
        "immunities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "vulnerabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "condition_immunities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "save_advantages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Advantage on saving throws by ability ID or scope keyword. Scope keywords: concentration, death, spells."
        },
        "condition_advantages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition", "effect"],
            "additionalProperties": false,
            "properties": {
              "condition": { "type": "string" },
              "effect": {
                "type": "string",
                "enum": ["avoid_or_end", "end"]
              }
            }
          }
        }
      }
    },
    "hit_points": {
      "type": "object",
      "required": ["max"],
      "additionalProperties": false,
      "properties": {
        "max": {
          "type": "integer",
          "minimum": 1,
          "description": "Full Hit Point maximum, before any temporary reduction or boost."
        }
      }
    },
    "hit_dice": {
      "description": "Hit dice by die size. Keys like 'd8', 'd10'. Max only — no remaining counters.",
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^d\\d+$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["max"],
        "additionalProperties": false,
        "properties": {
          "max": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "resource_budgets": {
      "description": "Per-resource maximums. Key identifies the resource (class resource, feature use, etc.). max: null = unlimited. No remaining counters — those live in MODIFIER.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["max"],
        "additionalProperties": false,
        "properties": {
          "max": {
            "type": ["integer", "null"],
            "minimum": 0
          }
        }
      }
    },
    "languages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "proficiencies": {
      "type": "object",
      "required": ["armor", "weapons", "tools"],
      "additionalProperties": false,
      "properties": {
        "armor": {
          "type": "array",
          "items": { "type": "string" }
        },
        "weapons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "weapon_masteries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "source": { "type": "string" },
          "choices": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "feats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "source": { "type": "string" },
          "ability_increase": {
            "description": "An ability-score increase a feat/boon confers: a single {ability, amount} object (a +2 to one ability), OR a list of them (a +1/+1 split across two abilities), OR null.",
            "oneOf": [
              {
                "type": "object",
                "required": ["ability", "amount"],
                "additionalProperties": false,
                "properties": {
                  "ability": { "type": "string" },
                  "amount": { "type": "integer" }
                }
              },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["ability", "amount"],
                  "additionalProperties": false,
                  "properties": {
                    "ability": { "type": "string" },
                    "amount": { "type": "integer" }
                  }
                }
              },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "companions": {
      "description": "Secondary creatures the character controls. Identity only — gameplay stats live in COMPANION_MODIFIER.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "db_creature_id"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "db_creature_id": {
            "type": "string",
            "description": "Link to the DB creature catalog entry that defines base stats."
          },
          "cast_level": {
            "type": ["integer", "null"],
            "minimum": 1,
            "maximum": 9,
            "description": "For a summoned/scaling companion: the spell slot level it was cast/summoned at. Drives the creature's scaling formulas. null for a companion whose block does not scale with a spell level."
          },
          "form": {
            "type": ["string", "null"],
            "description": "For a companion whose statblock has multiple summoned forms/environments, the chosen form identifier used to select the correct scaling-formula variant. null when the creature has a single form."
          },
          "kind": {
            "type": ["string", "null"]
          },
          "source": {
            "type": ["string", "null"]
          },
          "size": {
            "type": ["string", "null"]
          },
          "creature_type": {
            "type": ["string", "null"]
          },
          "duration": {
            "type": ["string", "null"]
          },
          "notes": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "permanent_effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "description"],
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "flavour": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "personality": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "traits": {
              "type": "array",
              "items": { "type": "string" }
            },
            "ideals": { "type": "string" },
            "bonds": { "type": "string" },
            "flaws": { "type": "string" }
          }
        },
        "physical": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "age": {
              "type": ["string", "integer", "null"]
            },
            "height": {
              "type": ["string", "null"]
            },
            "weight": {
              "type": ["string", "null"]
            },
            "eyes": {
              "type": ["string", "null"]
            },
            "skin": {
              "type": ["string", "null"]
            },
            "hair": {
              "type": ["string", "null"]
            }
          }
        },
        "backstory": {
          "type": ["string", "null"]
        }
      }
    }
  },
  "$defs": {
    "classEntry": {
      "type": "object",
      "required": ["class", "level"],
      "additionalProperties": false,
      "properties": {
        "class": { "type": "string" },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "subclass": {
          "type": ["string", "null"]
        },
        "subclass_detail": {
          "type": ["string", "null"]
        },
        "class_detail": {
          "type": ["string", "null"]
        }
      }
    },
    "abilityEntry": {
      "description": "One ability. base = pre-increase assignment. final = score after background bonus + feat/ASI bumps. No modifier or reduction.",
      "type": "object",
      "required": ["final"],
      "additionalProperties": false,
      "properties": {
        "base": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "background_bonus": {
          "type": "integer"
        },
        "final": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        }
      }
    }
  }
}
