{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:arcane:contract:companion-modifier:1",
  "title": "CompanionModifier",
  "description": "Companion gameplay stats — the companion's 'scratch paper' during a session. Each entry links back to a CORE companion identity via companion_index. Base creature stats come from the DB (referenced by CORE.companions[].db_creature_id); this sheet records effective current values after all modifiers (spells, HP scaling, shape-change effects, active states). Content-neutral: catalog-driven.",
  "type": "object",
  "required": [
    "schema_version",
    "character_id",
    "character_name",
    "companion_modifiers"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "character_id": {
      "type": "string"
    },
    "character_name": {
      "type": "string"
    },
    "companion_modifiers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/companionModifier"
      }
    }
  },
  "$defs": {
    "companionModifier": {
      "description": "Effective current stats for one companion. Links to CORE.companions[] by index. Creature base stats come from DB; this records the resolved values after all active modifiers.",
      "type": "object",
      "required": [
        "companion_index",
        "hit_points",
        "speed"
      ],
      "additionalProperties": false,
      "properties": {
        "companion_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Index into CORE.companions[] array."
        },
        "armor_class": {
          "type": ["integer", "null"],
          "description": "Effective AC including any spell bonuses (Mage Armor, Shield of Faith)."
        },
        "hit_points": {
          "type": "object",
          "required": ["max", "current"],
          "additionalProperties": false,
          "properties": {
            "max": {
              "type": "integer",
              "minimum": 0,
              "description": "Current maximum HP (may differ from base creature due to spell effects, HP scaling with caster level)."
            },
            "current": {
              "type": "integer"
            },
            "temp": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          }
        },
        "hit_dice": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^d\\d+$"
          },
          "additionalProperties": {
            "type": "object",
            "required": ["max"],
            "additionalProperties": false,
            "properties": {
              "max": {
                "type": "integer",
                "minimum": 0
              },
              "remaining": {
                "type": "integer",
                "minimum": 0,
                "default": 0
              }
            }
          }
        },
        "initiative_bonus": {
          "type": "integer",
          "default": 0
        },
        "multiattack": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of attacks the companion's multi-attack action makes. Formula-scaled by the summoning spell level for templated creatures; null/absent when the creature has no multi-attack action."
        },
        "proficiency_bonus": {
          "type": ["integer", "null"],
          "minimum": 2,
          "maximum": 6
        },
        "ability_scores": {
          "type": "object",
          "minProperties": 1,
          "description": "Effective ability scores after all modifiers. Key = ability catalog ID (str, dex, con, int, wis, cha).",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1,
            "maximum": 30
          }
        },
        "saving_throws": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ability", "modifier"],
            "additionalProperties": false,
            "properties": {
              "ability": {
                "type": "string",
                "description": "Ability catalog identifier."
              },
              "modifier": {
                "type": "integer"
              }
            }
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "bonus"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Skill catalog identifier."
              },
              "bonus": {
                "type": "integer"
              }
            }
          }
        },
        "passive_perception": {
          "type": ["integer", "null"]
        },
        "speed": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          },
          "description": "Effective movement speeds after all modifiers. Key = mode catalog ID -> feet."
        },
        "senses": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          },
          "description": "Effective special senses after all modifiers. Key = sense catalog ID -> range in feet."
        },
        "defenses": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "resistance": {
              "type": "array",
              "items": { "type": "string" }
            },
            "immunity": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "damage": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "condition": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "vulnerability": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "attacks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "attack_bonus": {
                "type": ["string", "integer", "null"]
              },
              "damage": {
                "type": ["string", "null"]
              },
              "damage_type": {
                "type": ["string", "null"]
              },
              "save_dc": {
                "type": ["integer", "null"],
                "description": "Save DC for an action/ability that forces a saving throw. Formula-scaled from the owner's spell save DC for templated creatures."
              },
              "properties": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "character_states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/companionState"
          },
          "description": "Companion active states. Same structure as MODIFIER character_states. Tracks companion-specific conditions: concentrating (if casting), poisoned, invisible, hidden, dodging, etc."
        }
      }
    },
    "companionState": {
      "description": "One active state affecting the companion. Same shape as MODIFIER characterState.",
      "type": "object",
      "required": ["state", "source", "source_type"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "description": "State catalog ID."
        },
        "source": {
          "type": "string",
          "description": "What caused this state."
        },
        "source_type": {
          "type": "string",
          "enum": ["feature", "spell", "feat", "item", "condition", "effect", "action", "species", "class_resource"]
        },
        "duration": {
          "type": ["string", "null"]
        },
        "level": {
          "type": ["integer", "null"]
        },
        "detail": {
          "type": "object"
        }
      }
    }
  }
}
