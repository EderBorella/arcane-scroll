# Copy to .env and fill per host. .env is gitignored.

# Model tag the generator uses; idempotently pulled into Ollama at startup.
MODEL=qwen3:4b-instruct-2507-q4_K_M

# Host port the generator API is published on (put Nginx Proxy Manager in front for real ingress).
GENERATOR_PORT=8080

# Host port the validator API is published on.
VALIDATOR_PORT=8090

# Host port the orchestrator API is published on.
ORCHESTRATOR_PORT=8100

# Host path to the compiled reference DB, mounted read-only into the generator and validator at
# /rules/rules.db. The data-access layer reads it via $ARCANE_RULES_DB (set to the container path in
# docker-compose.yml).
ARCANE_RULES_DB_HOST=/srv/arcane-scroll/rules.db

# Local (non-container) runs read the reference DB from this path. (The test suite builds its own
# synthetic DB in a temp dir and sets ARCANE_RULES_DB itself, so it never reads this value.)
ARCANE_RULES_DB=/srv/arcane-scroll/rules.db
