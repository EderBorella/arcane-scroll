# Copy to .env and fill per host. .env is gitignored.

# Absolute host path to the local reference data directory (contains records/ and catalog.json).
# Mounted read/write into the app at /data; the catalog DB is (re)built there at startup.
ARCANE_DATA_DIR_HOST=/srv/arcane-scroll/data

# Model tag the app uses; idempotently pulled into Ollama at startup.
MODEL=qwen3:4b-instruct-2507-q4_K_M

# Host port the API is published on (put Nginx Proxy Manager in front for real ingress).
APP_PORT=8080

# Validator micro-service. Host path to its rules data dir (produced by validator/build_rules.py);
# mounted read-only into the container at /rules.
VALIDATOR_DATA_DIR_HOST=/srv/arcane-scroll/validator-data
# Host path to the reference source JSON that build_rules.py reads to (re)generate the rules data.
SOURCE_JSON=/srv/arcane-scroll/reference.json
# Host port the validator API is published on.
VALIDATOR_PORT=8090
